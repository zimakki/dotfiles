# vim: set ft=gitconfig :
[user]
	name = Zi Makki
	email = zimakki@gmail.com

[github]
	user = zimakki

[url "git@github.com:"]
	insteadOf = https://github.com/

[core]
  pager = delta
	excludesfile = /Users/zimakki/.gitignore_global

[alias]
	lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --date=relative
	lg1 = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --date=relative --name-status
	lg2 = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --date=relative -p
	lg3 = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --date=relative -p --stat
	lg4 = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --date=relative -p --stat --graph
	lg5 = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --date=relative -p --stat --graph --reflog

[interactive]
	editor = nvim
	diffFilter = delta --color-only

[delta]
	navigate = true
	light = false
	line-numbers = true
	true-color = always
	syntax-theme = Catppuccin Mocha
	features = side-by-side-view

[merge]
	conflictStyle = diff3

[diff]
	colorMoved = default

[init]
	defaultBranch = main

[delta "side-by-side-view"]
	side-by-side = true
[credential "https://github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
