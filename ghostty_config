# vim: set ft=conf :
font-family = FiraCode Nerd Font Mono
font-size = 13
theme = TokyoNight Storm

# Dim unfocused splits to highlight active pane (0.15-1.0, lower = more dim)
unfocused-split-opacity = 0.15
unfocused-split-fill = #1a1b26
split-divider-color = #7aa2f7

# Split navigation (matching Warp: shift+cmd+H/J/K/L)
keybind = shift+cmd+k=goto_split:top
keybind = shift+cmd+j=goto_split:bottom
keybind = shift+cmd+h=goto_split:left
keybind = shift+cmd+l=goto_split:right

# Toggle split zoom (matching Warp: alt+cmd+enter)
keybind = alt+cmd+enter=toggle_split_zoom
